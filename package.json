{
  "name": "antigravity-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"backend,frontend\" -c \"cyan,magenta\" \"npm run dev -w apps/edge-backend\" \"npm run dev -w apps/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.45.1",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0"
  }
}
